{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/server.js",
      "routePrefix": "/api",
      "framework": "express",
      "maxDuration": 30
    }
  }
}
